    %%   MODULE : MATÉRIEL & ENGINS
    %% ═══════════════════════════════════════════════════
    class Engin {
        +String code
        +String nom
        +TypeEngin type
        +String marque
        +String modele
        +String immatriculation
        +String numeroSerie
