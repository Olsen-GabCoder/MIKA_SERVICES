# ===========================================
# MIKA Services — Frontend (Vite)
# ===========================================
# Données : priorité backend (base de données réelle).
# VITE_USE_MOCK=true  → tout en mock (aucun appel backend).
# VITE_USE_MOCK=false ou absent → backend uniquement (données BDD).
VITE_USE_MOCK=false

# Secours mock si backend indisponible (désactivé pour travailler en conditions réelles).
VITE_USE_MOCK_FALLBACK=false

# URL de l'API backend (optionnel si proxy Vite configuré dans vite.config).
# VITE_API_BASE_URL=http://localhost:8080
