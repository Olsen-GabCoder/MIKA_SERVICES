        +LocalDate dateRevision
    }

    class Prevision {
        +Integer semaine
        +Integer annee
        +TypePrevision type
        +LocalDate dateDebut
        +LocalDate dateFin
        +Integer avancementPct
    }

    class AvancementEtudeProjet {
        +PhaseEtude phase
        +BigDecimal avancementPct
        +LocalDate dateDepot
        +String etatValidation
