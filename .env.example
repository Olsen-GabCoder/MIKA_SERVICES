# MIKA Services – variables pour docker-compose (phase de test)
# Copier en .env et adapter. Ne pas committer .env avec des secrets réels.

# MySQL
MYSQL_ROOT_PASSWORD=mika_test_root
MYSQL_DATABASE=mika_services

# Backend (obligatoire en prod)
JWT_SECRET=change-me-in-production-long-random-string

# CORS et frontend (si vous accédez à l’app depuis une autre origine)
# CORS_ALLOWED_ORIGINS=http://localhost,https://votre-app.vercel.app
# FRONTEND_BASE_URL=https://votre-app.vercel.app
