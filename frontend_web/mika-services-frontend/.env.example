# Données : priorité backend (BDD réelle). Mettre true pour forcer le mock.
# VITE_USE_MOCK=false  → backend uniquement (recommandé en dev avec seed BDD).
# VITE_USE_MOCK_FALLBACK=false  → pas de secours mock (erreurs visibles si backend down).
VITE_USE_MOCK=false
VITE_USE_MOCK_FALLBACK=false

# API (optionnel si proxy Vite vers le backend)
# VITE_API_BASE_URL=http://localhost:8080
