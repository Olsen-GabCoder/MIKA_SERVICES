    class CAPrevisionnelRealise {
        +Integer mois
        +Integer annee
        +BigDecimal caPrevisionnel
        +BigDecimal caRealise
        +BigDecimal ecart
        +BigDecimal avancementCumule
    }

    class RevisionBudget {
        +BigDecimal ancienMontant
        +BigDecimal nouveauMontant
