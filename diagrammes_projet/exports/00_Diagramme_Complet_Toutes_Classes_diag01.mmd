    %% ═══════════════════════════════════════════════════
    %%   MODULE : COMMUNICATION
    %% ═══════════════════════════════════════════════════
    class Message {
        +String sujet
        +String contenu
        +LocalDateTime dateEnvoi
        +Boolean lu
        +LocalDateTime dateLecture
    }

    class Notification {
        +String titre
        +String contenu
